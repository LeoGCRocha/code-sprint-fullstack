                    {
                      "type": "text",
                      "id": "811Nr",
                      "x": 20,
                      "y": 78,
                      "name": "body1",
                      "fill": "#221912",
                      "content": "Given an integer N, find its prime factorization. However, standard prime factorization\nalgorithms can be too slow for very large numbers. Your task is to implement an optimized\napproach that can handle up to Q queries efficiently.",
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "AymtP",
                      "x": 20,
                      "y": 146,
                      "name": "body2",
                      "fill": "#221912",
                      "content": "For each query, you will be given an integer X. You need to output the prime factors of X\nin ascending order, along with their respective powers.",
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
