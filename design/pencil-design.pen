                          "x": 24,
                          "y": 11,
                          "name": "noteText",
                          "fill": "#6E4E3B",
                          "content": "Note: A naive O(sqrt(N)) approach per query will result in Time Limit Exceeded (TLE).\nConsider precomputing using a sieve if appropriate.",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
