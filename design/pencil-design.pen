                          "content": "⚠ Context Clarification",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "RcBXg",
                          "x": 14,
                          "y": 30,
                          "name": "clarBody",
                          "fill": "#8B4513",
                          "textGrowth": "fixed-width",
                          "width": 794,
                          "content": "The starting cell (0, 0) and ending cell (n-1, n-1) are guaranteed to be 0. The path length is the number of cells visited, including the start and end cells.",
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
