                      ]
                    },
                    {
                      "type": "text",
                      "id": "R77Jl",
                      "x": 20,
                      "y": 70,
                      "name": "body1",
                      "fill": "#221912",
                      "textGrowth": "fixed-width",
                      "width": 822,
                      "content": "You are given an n × n binary matrix grid, where 0 represents an empty cell and 1 represents an obstacle. You can move up, down, left, or right from and to an empty cell.",
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "pEtPL",
                      "x": 20,
                      "y": 124,
                      "name": "body2",
                      "fill": "#221912",
                      "textGrowth": "fixed-width",
                      "width": 822,
                      "content": "Return the length of the shortest clear path from the top-left cell (0, 0) to the bottom-right cell (n − 1, n − 1). If there is no clear path, return -1.",
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "N9AGDg",
                      "x": 20,
                      "y": 168,
                      "name": "body3",
                      "fill": "#221912",
                      "content": "A clear path is defined as a sequence of cells C1, C2, ..., Ck such that:",
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "Z5OSY",
                      "x": 20,
                      "y": 192,
                      "name": "bulletList",
                      "width": 822,
                      "layout": "vertical",
                      "gap": 4,
                      "children": [
                        {
                          "type": "text",
                          "id": "NI5Z8",
                          "name": "bl1",
                          "fill": "#221912",
                          "content": "• C1 is at (0, 0)",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Yp7ny",
                          "name": "bl2",
                          "fill": "#221912",
                          "content": "• Ck is at (n − 1, n − 1)",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "S71iR",
                          "name": "bl3",
                          "fill": "#221912",
                          "content": "• All cells in the sequence are empty (i.e., grid[r][c] == 0)",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LFqiY",
                          "name": "bl4",
                          "fill": "#221912",
                          "textGrowth": "fixed-width",
                          "width": 822,
                          "content": "• Adjacent cells in the sequence share an edge (they are horizontally or vertically adjacent)",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "kOCbg",
                      "x": 20,
                      "y": 308,
                      "name": "clarBox",
                      "width": 822,
                      "height": 66,
                      "fill": "#FFF5F0",
